[LUsbK_Device_AddReg]
HKR,,DeviceInterfaceGUIDs,0x10000,"{%src.device1.guid%, %src.device2.guid%, %src.device3.guid%, %src.device4.guid%, %src.device5.guid%, %src.device6.guid%, %src.device7.guid%, %src.device8.guid%, %src.device9.guid%, %src.device10.guid%, %src.device11.guid%, %src.device12.guid%, %src.device13.guid%, %src.device14.guid%, %src.device15.guid%, %src.device16.guid%, %src.device17.guid%, %src.device18.guid%, %src.device19.guid%, %src.device20.guid%, %src.device21.guid%, %src.device22.guid%, %src.device23.guid%, %src.device24.guid%, %src.device25.guid%, %src.device26.guid%, %src.device27.guid%, %src.device28.guid%, %src.device29.guid%, %src.device30.guid%, %src.device31.guid%, %src.device32.guid%, %src.device33.guid%, %src.device34.guid%, %src.device35.guid%, %src.device36.guid%, %src.device37.guid%, %src.device38.guid%, %src.device39.guid%, %src.device40.guid%, %src.device41.guid%, %src.device42.guid%, %src.device43.guid%, %src.device44.guid%, %src.device45.guid%, %src.device46.guid%, %src.device47.guid%, %src.device48.guid%, %src.device49.guid%, %src.device50.guid%, %src.device51.guid%, %src.device52.guid%, %src.device53.guid%, %src.device54.guid%, %src.device55.guid%, %src.device56.guid%, %src.device57.guid%, %src.device58.guid%, %src.device59.guid%, %src.device60.guid%, %src.device61.guid%, %src.device62.guid%, %src.device63.guid%, %src.device64.guid%, %src.device65.guid%}"

HKR,,DeviceIdleEnabled,0x00010001,1

HKR,,DefaultIdleState,0x00010001,0

HKR,,DefaultIdleTimeout,0x00010001,5000

HKR,,DeviceIdleIgnoreWakeEnable,0x00010001,0

HKR,,UserSetDeviceIdleEnabled,0x00010001,0

HKR,,SystemWakeEnabled,0x00010001,0

[LUsbK_Device.NT.Services]
Addservice=libusbK,2,LUsbK_AddService

[LUsbK_Device.NTAMD64.Services]
Addservice=libusbK,2,LUsbK_AddService

[LUsbK_AddService]
DisplayName="libusbK USB Driver 04/28/2014 - 3.0.7.0"
ServiceType=1
StartType=3
ErrorControl=1
ServiceBinary=%12%\libusbK.sys
AddReg=LUsbK_Driver_AddReg

[LUsbK_Driver_AddReg]
HKR,"Parameters","DebugLevel",0x10001,4

[SourceDisksNames]
1 = %SourceName%

[SourceDisksFiles.x86]
libusbK.sys	= 1,x86
libusbK_x86.dll	= 1,x86
WdfCoInstaller01009.dll = 1,x86

[SourceDisksFiles.amd64]
WdfCoInstaller01009.dll	= 1,amd64
libusbK.sys			= 1,amd64
libusbK.dll			= 1,amd64
libusbK_x86.dll		= 1,x86

[DestinationDirs]
DefaultDestDir				= 12
CoInstaller_CopyFiles		= 11
libusb_files_sys		= 10,system32\drivers
libusb_files_dll		= 10,system32
libusb_files_dll_wow64	= 10,syswow64
libusb_files_dll_x86	= 10,system32

[libusb_files_sys]
libusbK.sys

[libusb_files_dll]
libusbK.dll

[libusb_files_dll_x86]
libusbK.dll, libusbK_x86.dll

[libusb_files_dll_wow64]
libusbK.dll, libusbK_x86.dll

[LUsbK_Device.NT]
CopyFiles = libusb_files_sys, libusb_files_dll_x86

[LUsbK_Device.NTAMD64]
CopyFiles = libusb_files_sys, libusb_files_dll, libusb_files_dll_wow64

; ========= WDF/CoInstaller section =============
[LUsbK_Device.NT.CoInstallers]
AddReg=CoInstaller_AddReg
CopyFiles=CoInstaller_CopyFiles

[LUsbK_Device.NTAMD64.CoInstallers]
AddReg=CoInstaller_AddReg
CopyFiles=CoInstaller_CopyFiles

[CoInstaller_CopyFiles]
WdfCoInstaller01009.dll

[CoInstaller_AddReg]
HKR,,CoInstallers32,0x00010000, "WdfCoInstaller01009.dll,WdfCoInstaller"

[LUsbK_Device.NT.Wdf]
KmdfService = libusbK, LUsbK_wdfsect

[LUsbK_Device.NTAMD64.Wdf]
KmdfService = libusbK, LUsbK_wdfsect

[LUsbK_wdfsect]
KmdfLibraryVersion=1.9
